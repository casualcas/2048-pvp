{
  "expo": {
    "name": "2048 PvP",
    "slug": "2048-pvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pvp2048.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pvp2048.app",
      "googleMobileAdsAppId": "ca-app-pub-7052877159805288~1929926938",
      "versionCode": 4,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7052877159805288~1929926938",
          "iosAppId": "ca-app-pub-7052877159805288~1929926938"
        }
      ],
      "expo-web-browser",
      "expo-localization",
      "expo-audio",
      "./copy-adi-plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "985c078a-252a-4502-b603-e149201791ad"
      }
    },
    "scheme": "com.battle2048.app",
    "owner": "nininbini",
    "backgroundColor": "#1a1a2e"
  }
}